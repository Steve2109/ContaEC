PORT=80
DEBUG=False

# Seguridad
JWT_SECRET_KEY=GENERA_UN_SECRETO_LARGO_CON_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
MASTER_ENCRYPTION_KEY=GENERA_OTRA_CLAVE_LARGA_DISTINTA
CORS_ORIGINS=https://conta.tymtechnology.shop,http://10.0.1.20
